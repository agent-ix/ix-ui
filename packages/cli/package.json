{
  "name": "@agent-ix/ix-ui-cli",
  "description": "Terminal UI components for the Agent IX CLI ecosystem.",
  "version": "0.4.0",
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "test": "vitest run",
    "test:json": "vitest run --reporter=json --outputFile=report.json || true",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" && pnpm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "vite build",
    "clean": "rm -rf dist coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-ix/ix-ui.git"
  },
  "dependencies": {
    "@agent-ix/ix-ui-semantic": "workspace:*",
    "execa": ">=9.5.1",
    "ink": ">=5.0.1",
    "ink-select-input": ">=6.0.0",
    "ink-spinner": ">=5.0.0",
    "ink-text-input": ">=6.0.0",
    "picocolors": ">=1.1.1",
    "react": ">=18.3.1"
  },
  "devDependencies": {
    "@types/react": ">=18.3.12",
    "ink-testing-library": ">=4.0.0",
    "vite": ">=6.3.4",
    "vite-plugin-dts": ">=4.5.3",
    "vitest": ">=3.1.2"
  }
}
